# Copy to .env.local. Both variables are OPTIONAL.
# Without an API key the app runs on the deterministic rules + templates path and
# still works end to end — useful for offline demos.

# Enables the AI extraction + recommendation steps (Anthropic Claude).
ANTHROPIC_API_KEY=

# Override the model. Defaults to claude-sonnet-4-6.
# LLM_MODEL=claude-sonnet-4-6
